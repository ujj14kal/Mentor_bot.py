# ── Telegram MTProto credentials (from https://my.telegram.org) ──
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── Groq AI (free, from https://console.groq.com) ──
GROQ_API_KEY=

# ── Google Sheets ──
GOOGLE_CREDS_FILE=google_creds.json

# ── Your Telegram user ID (get from @userinfobot on Telegram) ──
YOUR_TELEGRAM_ID=

# ── Eyeconic OPS Tele group chat ID ──
OPS_GROUP_ID=

# ── Timezone ──
TIMEZONE=Asia/Kolkata
